#!/usr/bin/env bash
# Install code-outline-graph from source.
# Requires: go 1.23+, git, gcc (CGo for go-sqlite3)
#
# Usage:
#   curl -fsSL https://github.com/rushikesh-sakharle/gocode-outline-graph/raw/main/go-code-outline-graph | bash
#   bash go-code-outline-graph [--prefix /usr/local]

set -euo pipefail

REPO_URL="https://github.com/rushikeshsakharleofficial/gocode-outline-graph.git"
BINARY_NAME="code-outline-graph-go"
MIN_GO_MAJOR=1
MIN_GO_MINOR=23

# ---------------------------------------------------------------------------
# Helpers
# ---------------------------------------------------------------------------

red()   { printf '\033[31m%s\033[0m\n' "$*"; }
green() { printf '\033[32m%s\033[0m\n' "$*"; }
dim()   { printf '\033[2m%s\033[0m\n'  "$*"; }
die()   { red "error: $*" >&2; exit 1; }

# run_with_spinner CMD [ARGS...] — runs CMD in background, shows spinner, propagates exit code.
run_with_spinner() {
    local msg="$1"; shift
    local spin='|/-\'
    local i=0
    "$@" &
    local pid=$!
    while kill -0 "$pid" 2>/dev/null; do
        local ch="${spin:$i:1}"
        printf '\r\033[2m%s\033[0m %s' "$ch" "$msg" >&2
        i=$(( (i + 1) % 4 ))
        sleep 0.1
    done
    wait "$pid"
    local code=$?
    printf '\r\033[K' >&2
    return $code
}

# ---------------------------------------------------------------------------
# Resolve install prefix
# ---------------------------------------------------------------------------

PREFIX=""
while [[ $# -gt 0 ]]; do
    case "$1" in
        --prefix) PREFIX="$2"; shift 2 ;;
        --prefix=*) PREFIX="${1#--prefix=}"; shift ;;
        *) die "unknown argument: $1" ;;
    esac
done

if [[ -z "$PREFIX" ]]; then
    if [[ -n "${GOPATH:-}" && -d "$GOPATH/bin" ]]; then
        INSTALL_DIR="$GOPATH/bin"
    elif [[ -d "$HOME/.local/bin" ]]; then
        INSTALL_DIR="$HOME/.local/bin"
    elif [[ -w "/usr/local/bin" ]]; then
        INSTALL_DIR="/usr/local/bin"
    else
        INSTALL_DIR="$HOME/.local/bin"
        mkdir -p "$INSTALL_DIR"
    fi
else
    INSTALL_DIR="$PREFIX/bin"
    mkdir -p "$INSTALL_DIR"
fi

# ---------------------------------------------------------------------------
# Dependency checks
# ---------------------------------------------------------------------------

check_go() {
    command -v go >/dev/null 2>&1 || die "go not found. Install from https://go.dev/dl/"
    local ver
    ver=$(go version | grep -oP 'go\K[0-9]+\.[0-9]+' | head -1)
    local major minor
    major=$(echo "$ver" | cut -d. -f1)
    minor=$(echo "$ver" | cut -d. -f2)
    if (( major < MIN_GO_MAJOR || (major == MIN_GO_MAJOR && minor < MIN_GO_MINOR) )); then
        die "go $MIN_GO_MAJOR.$MIN_GO_MINOR+ required (found go $ver)"
    fi
}

check_cc() {
    command -v cc >/dev/null 2>&1 || command -v gcc >/dev/null 2>&1 || \
        die "C compiler not found (needed for go-sqlite3 CGo). Install gcc."
}

check_git() {
    command -v git >/dev/null 2>&1 || die "git not found"
}

dim "Checking dependencies..."
check_go
check_cc
check_git
green "  go $(go version | grep -oP 'go\K[0-9.]+' | head -1) — ok"
green "  cc  — ok"
green "  git — ok"

# ---------------------------------------------------------------------------
# Clone into temp dir and build
# ---------------------------------------------------------------------------

TMPDIR=$(mktemp -d)
trap 'rm -rf "$TMPDIR"' EXIT

run_with_spinner "Cloning $REPO_URL..." \
    git clone --depth=1 --quiet "$REPO_URL" "$TMPDIR/src" \
    || die "git clone failed"
green "  Cloned"

cd "$TMPDIR/src"
run_with_spinner "Building (CGo + FTS5)..." \
    go build \
        -buildvcs=false \
        -tags fts5 \
        -ldflags "-s -w" \
        -o "$TMPDIR/$BINARY_NAME" \
        ./cmd/code-outline-graph/ \
    || die "go build failed"
green "  Built"

# ---------------------------------------------------------------------------
# Install
# ---------------------------------------------------------------------------

DEST="$INSTALL_DIR/$BINARY_NAME"
mv "$TMPDIR/$BINARY_NAME" "$DEST"
chmod +x "$DEST"

green ""
green "Installed: $DEST"
dim   "  version: $("$DEST" version 2>/dev/null || echo 'unknown')"

# ---------------------------------------------------------------------------
# PATH hint
# ---------------------------------------------------------------------------

if ! echo ":${PATH}:" | grep -q ":${INSTALL_DIR}:"; then
    printf '\n'
    red  "  Warning: $INSTALL_DIR is not in your PATH."
    dim  "  Add to your shell profile:"
    dim  "    export PATH=\"\$PATH:$INSTALL_DIR\""
    printf '\n'
fi

# ---------------------------------------------------------------------------
# MCP config
# ---------------------------------------------------------------------------

dim "Writing MCP config for editors (Claude Code, Cursor, Claude Desktop)..."
"$DEST" install 2>/dev/null || true

green ""
green "Done. Run: $BINARY_NAME --help"
